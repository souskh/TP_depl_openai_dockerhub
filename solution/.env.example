# Copy to .env — token: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_key_here
# Optional: chat model for router (default in code: meta-llama/Llama-3.2-1B-Instruct)
# HUGGINGFACE_MODEL=meta-llama/Llama-3.2-1B-Instruct
# Optional label in JSON {"model": "..."} (default: last segment of HUGGINGFACE_MODEL)
# API_RESPONSE_MODEL=Llama-3.2-1B-Instruct
